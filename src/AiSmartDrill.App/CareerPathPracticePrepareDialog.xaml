<Window x:Class="AiSmartDrill.App.CareerPathPracticePrepareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CareerPath 刷题准备"
        Width="640"
        MinHeight="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.Text}">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Padding="18,8" Margin="0,0,10,0" Click="OnCancel" />
            <Button Content="开始刷题" Padding="18,8" IsDefault="True" Click="OnConfirm" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" Opacity="0.9"
                           Text="已根据技能包检索题库：下列为各知识点命中题数及按领域汇总。请选择筛选条件后开始组卷。" />

                <TextBlock Margin="0,14,0,4" FontWeight="SemiBold" Text="知识点命中" />
                <TextBox x:Name="TbPerSkill" Height="100" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />

                <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="按领域汇总（命中技能的题目）" />
                <TextBox x:Name="TbByDomain" Height="72" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />

                <TextBlock x:Name="TbInfer" Margin="0,12,0,0" TextWrapping="Wrap" />

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,10" Text="领域" />
                    <ComboBox x:Name="CbDomain" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" />

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,10" Text="难度" />
                    <ComboBox x:Name="CbDifficulty" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" />

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="本次题量" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <TextBox x:Name="TbCount" Width="72" VerticalContentAlignment="Center" />
                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Opacity="0.75" Text="（1～50）" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
