<Window x:Class="AiSmartDrill.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AiSmartDrill.App.ViewModels"
        mc:Ignorable="d"
        Title="AI 智能题库与刷题系统"
        Height="760"
        Width="1180"
        Closed="MainWindow_OnClosed">
    <DockPanel Margin="16">
        <Border DockPanel.Dock="Top" Padding="14" CornerRadius="10" Background="{StaticResource Brush.Surface}" BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,12">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="AI 智能题库与刷题系统" />
                    <TextBlock Margin="0,6,0,0" Opacity="0.85" Text="WPF · EF Core SQLite · 火山方舟豆包（Chat Completions）" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Opacity="0.85" Text="{Binding StatusMessage}" TextWrapping="Wrap" MaxWidth="520" />
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="10" CornerRadius="8" Background="#0B1220" BorderBrush="#334155" BorderThickness="1" Margin="0,12,0,0">
            <TextBlock Opacity="0.75" Text="单选/多选点选项按钮；判断点「对」「错」；简答按关键词；填空题标准答案填正则表达式判分。" TextWrapping="Wrap" />
        </Border>

        <TabControl x:Name="MainTabControl">
            <TabItem Header="题库管理">
                <DockPanel Margin="0,10,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Label Content="题型" VerticalAlignment="Center" />
                        <ComboBox Width="120" ItemsSource="{Binding TypeFilterOptions}" SelectedItem="{Binding SelectedTypeFilter}" />
                        <Label Margin="12,0,0,0" Content="难度" VerticalAlignment="Center" />
                        <ComboBox Width="120" ItemsSource="{Binding DifficultyFilterOptions}" SelectedItem="{Binding SelectedDifficultyFilter}" />
                        <Label Margin="12,0,0,0" Content="领域" VerticalAlignment="Center" />
                        <ComboBox Width="150" ItemsSource="{Binding DomainFilterOptions}" SelectedItem="{Binding SelectedDomainFilter}" />
                        <Button Content="刷新题库" Command="{Binding RefreshBankCommand}" />
                        <Button Content="新建题目" Command="{Binding NewQuestionCommand}" />
                        <Button Content="保存题目" Command="{Binding SaveQuestionCommand}" />
                        <Button Content="删除题目" Command="{Binding DeleteQuestionCommand}" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0"
                                  Margin="0,0,12,0"
                                  ItemsSource="{Binding BankQuestions}"
                                  SelectedItem="{Binding SelectedBankQuestion}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60" />
                                <DataGridTextColumn Header="题型" Binding="{Binding Type}" Width="90" />
                                <DataGridTextColumn Header="难度" Binding="{Binding Difficulty}" Width="90" />
                                <DataGridTextColumn Header="标准答案" Binding="{Binding StandardAnswer}" Width="160" />
                                <DataGridTextColumn Header="题干" Binding="{Binding Stem}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Column="1">
                            <TextBlock FontWeight="SemiBold" Text="题目编辑器" Margin="0,0,0,8" />
                            <Label Content="题型" />
                            <ComboBox ItemsSource="{Binding EditorTypeOptions}" SelectedItem="{Binding EditorType}" />
                            <Label Content="难度" />
                            <ComboBox ItemsSource="{Binding EditorDifficultyOptions}" SelectedItem="{Binding EditorDifficulty}" />
                            <Label Content="领域" />
                            <ComboBox ItemsSource="{Binding EditorDomainOptions}" SelectedItem="{Binding EditorDomain}" />
                            <Label Content="题干" />
                            <TextBox Height="90" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding EditorStem, UpdateSourceTrigger=PropertyChanged}" />
                            <Label Content="标准答案（填空题为正则表达式）" />
                            <TextBox Text="{Binding EditorStandardAnswer, UpdateSourceTrigger=PropertyChanged}" />
                            <Label Content="选项 JSON（客观题）" />
                            <TextBox Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding EditorOptionsJson, UpdateSourceTrigger=PropertyChanged}" />
                            <Label Content="知识点标签" />
                            <TextBox Text="{Binding EditorKnowledgeTags, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="考试 / 刷题">
                <DockPanel Margin="0,10,0,0">
                    <Border DockPanel.Dock="Top" Padding="12" CornerRadius="10" Background="{StaticResource Brush.Surface}" BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel>
                            <WrapPanel ItemHeight="40">
                                <Label Content="题量" VerticalAlignment="Center" />
                                <TextBox Width="70" Text="{Binding ExamQuestionCount, UpdateSourceTrigger=PropertyChanged}" Height="32" />
                                <Label Margin="12,0,0,0" Content="时长(分)" VerticalAlignment="Center" />
                                <TextBox Width="70" Text="{Binding ExamMinutes, UpdateSourceTrigger=PropertyChanged}" Height="32" />
                                <Button Content="随机组卷并开始" Command="{Binding StartExamCommand}" Width="140" Height="35" />
                                <Button Content="交卷" Command="{Binding SubmitExamCommand}" Width="80" Height="35" />
                                <Button Content="取消做题" Command="{Binding CancelExamCommand}" Width="80" Height="35" />
                                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding LastScoreText, StringFormat=最近成绩：{0}}" />
                            </WrapPanel>
                            <TextBlock Margin="0,10,0,4"
                                       Opacity="0.88"
                                       TextWrapping="Wrap"
                                       Text="刷题领域：勾选一项或多项则仅从所选领域抽题；全部不勾选时，领域范围与「题库管理」页的领域下拉一致（选「全部」即不限领域）。" />
                            <ItemsControl ItemsSource="{Binding ExamDomainPicks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ExamDomainPickVm}">
                                        <CheckBox Margin="0,0,14,6"
                                                  VerticalAlignment="Center"
                                                  Content="{Binding DisplayName}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" Padding="12" CornerRadius="10" Background="#0B1220" BorderBrush="{StaticResource Brush.Accent}" BorderThickness="1" Margin="0,0,0,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" Text="倒计时（秒）" />
                            <TextBlock DockPanel.Dock="Left" Margin="10,0,0,0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Brush.Accent}" Text="{Binding ExamRemainingSeconds}" />
                            <TextBlock DockPanel.Dock="Right" Opacity="0.85" Text="{Binding ExamProgressLabel}" TextWrapping="Wrap" MaxWidth="420" TextAlignment="Right" />
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid MinHeight="200">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock FontWeight="SemiBold" Text="{Binding ExamTypeText, StringFormat=题型：{0}}" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding ExamDifficultyText, StringFormat=难度：{0}}" />
                            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" FontSize="16" Text="{Binding ExamStem}" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                MaxHeight="280"
                                Padding="12"
                                CornerRadius="10"
                                Background="{StaticResource Brush.Surface}"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Margin="0,0,0,10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock TextWrapping="Wrap" Opacity="0.9" Text="{Binding ExamOptionsDisplay}" />
                            </ScrollViewer>
                        </Border>

                        <DockPanel Grid.Row="2" LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="上一题" Command="{Binding ExamPrevCommand}" />
                                <Button Content="下一题" Command="{Binding ExamNextCommand}" />
                            </StackPanel>
                            <StackPanel>
                                <Label Content="你的答案" />
                                <ItemsControl Margin="0,0,0,8"
                                              Visibility="{Binding ExamShowMcqSinglePanel, Converter={StaticResource BoolToVisibility}}"
                                              ItemsSource="{Binding ExamMcqOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ExamOptionItemVm}">
                                            <Button MinWidth="120"
                                                    Margin="0,0,10,8"
                                                    Padding="12,8"
                                                    Content="{Binding Caption}"
                                                    Command="{Binding DataContext.ExamPickSingleOptionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#0F172A" />
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
                                                        <Setter Property="BorderBrush" Value="#334155" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                                                <Setter Property="BorderThickness" Value="2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl Margin="0,0,0,8"
                                              Visibility="{Binding ExamShowMcqMultiPanel, Converter={StaticResource BoolToVisibility}}"
                                              ItemsSource="{Binding ExamMcqOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ExamOptionItemVm}">
                                            <Button MinWidth="120"
                                                    Margin="0,0,10,8"
                                                    Padding="12,8"
                                                    Content="{Binding Caption}"
                                                    Command="{Binding DataContext.ExamToggleMultiOptionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#0F172A" />
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
                                                        <Setter Property="BorderBrush" Value="#334155" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                                                <Setter Property="BorderThickness" Value="2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal"
                                            Visibility="{Binding ExamShowTrueFalsePanel, Converter={StaticResource BoolToVisibility}}">
                                    <Button MinWidth="100"
                                            Margin="0,0,10,0"
                                            Padding="14,10"
                                            Content="对"
                                            Command="{Binding ExamPickTrueCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#0F172A" />
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
                                                <Setter Property="BorderBrush" Value="#334155" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ExamUserAnswer}" Value="对">
                                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button MinWidth="100"
                                            Padding="14,10"
                                            Content="错"
                                            Command="{Binding ExamPickFalseCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#0F172A" />
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
                                                <Setter Property="BorderBrush" Value="#334155" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ExamUserAnswer}" Value="错">
                                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                                <TextBox MinHeight="34"
                                         Visibility="{Binding ExamShowTextAnswerPanel, Converter={StaticResource BoolToVisibility}}"
                                         Text="{Binding ExamUserAnswer, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="错题本 / AI">
                <DockPanel Margin="0,10,0,0">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <!-- 单行横向滚动，避免窗口变窄时操作按钮被挤到视野外 -->
                        <ScrollViewer Grid.Row="0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      MinHeight="44"
                                      Padding="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="刷新错题本"
                                        Command="{Binding RefreshWrongBookCommand}"
                                        Margin="0,0,10,0"
                                        MinHeight="38"
                                        MinWidth="100"
                                        Padding="14,10" />
                                <Button Content="错题再练（组卷）"
                                        Command="{Binding StartWrongBookPracticeCommand}"
                                        Margin="0,0,10,0"
                                        MinHeight="38"
                                        MinWidth="120"
                                        Padding="14,10" />
                                <Button Content="AI 错题解析（已勾选）"
                                        Command="{Binding AiTutorAnalyzeWrongCommand}"
                                        Margin="0,0,10,0"
                                        MinHeight="38"
                                        MinWidth="150"
                                        Padding="14,10" />
                                <Button Content="AI 题目推荐"
                                        Command="{Binding RecommendCommand}"
                                        Margin="0,0,10,0"
                                        MinHeight="38"
                                        MinWidth="100"
                                        Padding="14,10" />
                                <Button Content="用推荐题开始考试"
                                        Command="{Binding StartExamFromRecommendationCommand}"
                                        MinHeight="38"
                                        MinWidth="132"
                                        Padding="14,10" />
                            </StackPanel>
                        </ScrollViewer>
                        <WrapPanel Grid.Row="1" Margin="0,6,0,0" ItemHeight="38">
                            <Label Content="领域筛选" VerticalAlignment="Center" />
                            <ComboBox Width="168"
                                      Margin="6,0,10,0"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding WrongBookDomainFilterOptions}"
                                      SelectedItem="{Binding WrongBookDomainFilter}" />
                            <Button Content="{Binding WrongBookSelectAllInFilterCaption}"
                                    Command="{Binding WrongBookSelectAllInFilterCommand}"
                                    Margin="0,0,12,0"
                                    MinHeight="34"
                                    MinWidth="112"
                                    Padding="12,8"
                                    VerticalAlignment="Center" />
                            <CheckBox VerticalAlignment="Center"
                                      MaxWidth="520"
                                      Content="长期保存错题详情（错答快照写入本地 SQLite）"
                                      IsChecked="{Binding PersistWrongBookDetails}" />
                        </WrapPanel>
                        <!-- 固定可视高度，超出换行并由纵向滚动条查看 -->
                        <Border Grid.Row="2"
                                Margin="0,8,0,0"
                                MaxHeight="72"
                                Padding="8,6"
                                CornerRadius="6"
                                Background="#0F172A"
                                BorderBrush="#334155"
                                BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <TextBlock Opacity="0.88"
                                           TextWrapping="Wrap"
                                           Text="勾选「解析」列将题目加入短时记忆；领域旁按钮可在当前列表「全选」与「全部不选」之间切换。AI 解析仅发送勾选题。「删除」移除错题本条目。完成「错题再练」并交卷后显示「已重做」。关闭长期保存时仍累计错次，但不写入错答文本。" />
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Border DockPanel.Dock="Top" Padding="10" CornerRadius="8" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="AI 请求状态" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource Brush.Accent}" FontWeight="SemiBold" Text="{Binding AiPipelinePhase}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding AiPipelineDetail}" TextWrapping="Wrap" Opacity="0.9" />
                            </StackPanel>
                            <GroupBox Grid.Column="1" Header="调用日志（调试）" Foreground="{StaticResource Brush.Text}">
                                <TextBox Text="{Binding AiPipelineLog, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MaxHeight="140" FontFamily="Consolas" FontSize="11" />
                            </GroupBox>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="错题列表（含错答 / 标答）" Margin="0,0,12,0" Foreground="{StaticResource Brush.Text}">
                            <DataGrid ItemsSource="{Binding WrongBookRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeColumns="True"
                                      HeadersVisibility="Column"
                                      ColumnHeaderHeight="40"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      MaxHeight="420"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="84" MinWidth="84" MaxWidth="84">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="76"
                                                       Text="解析"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <CheckBox HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsThreeState="False">
                                                    <CheckBox.LayoutTransform>
                                                        <ScaleTransform ScaleX="1.45" ScaleY="1.45" />
                                                    </CheckBox.LayoutTransform>
                                                </CheckBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="88" MinWidth="88" MaxWidth="88">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="80"
                                                       Text="领域"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <ScrollViewer MaxHeight="96"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <TextBlock Text="{Binding DomainDisplay}"
                                                               TextWrapping="Wrap"
                                                               Width="80" />
                                                </ScrollViewer>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="76" MinWidth="76" MaxWidth="76">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="68"
                                                       Text="题型"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <ScrollViewer MaxHeight="96"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <TextBlock Text="{Binding TypeDisplay}"
                                                               TextWrapping="Wrap"
                                                               Width="68" />
                                                </ScrollViewer>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="220" MinWidth="220" MaxWidth="220">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="200"
                                                       Text="题干"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <ScrollViewer MaxHeight="96"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <TextBlock Text="{Binding Stem}"
                                                               TextWrapping="Wrap"
                                                               Width="200" />
                                                </ScrollViewer>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="168" MinWidth="168" MaxWidth="168">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="150"
                                                       Text="你的错答"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <ScrollViewer MaxHeight="96"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <TextBlock Text="{Binding WrongAnswerDisplay}"
                                                               TextWrapping="Wrap"
                                                               Width="150" />
                                                </ScrollViewer>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="148" MinWidth="148" MaxWidth="148">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="132"
                                                       Text="标准答案"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <ScrollViewer MaxHeight="96"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <TextBlock Text="{Binding StandardAnswerDisplay}"
                                                               TextWrapping="Wrap"
                                                               Width="132" />
                                                </ScrollViewer>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="52" MinWidth="52" MaxWidth="52">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="44"
                                                       Text="错次"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock Text="{Binding WrongCount}"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="128" MinWidth="128" MaxWidth="128">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="118"
                                                       Text="最近错误"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <ScrollViewer MaxHeight="96"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <TextBlock Text="{Binding LastWrongAtDisplay}"
                                                               TextWrapping="Wrap"
                                                               Width="118" />
                                                </ScrollViewer>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="76" MinWidth="76" MaxWidth="76">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="68"
                                                       Text="已重做"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource Brush.Accent}"
                                                           Text="{Binding RedoTagDisplay}"
                                                           ToolTip="{Binding RedoTagToolTip}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="84" MinWidth="84" MaxWidth="84">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="72"
                                                       Text="操作"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <Button MinHeight="32"
                                                        Padding="10,6"
                                                        Content="删除"
                                                        Command="{Binding DataContext.DeleteWrongBookEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Column="1" Header="AI 输出（解析/推荐）" Foreground="{StaticResource Brush.Text}">
                            <Grid MinHeight="280">
                                <TextBox VerticalAlignment="Stretch"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding AiOutputText, Mode=OneWay}"
                                         IsReadOnly="True" />
                                <Border Background="#E60B1220"
                                        Visibility="{Binding AiMainOutputBusy, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Margin="28"
                                                MaxWidth="440">
                                        <TextBlock Text="{Binding AiMainOutputBusyMessage}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.Accent}" />
                                        <ProgressBar IsIndeterminate="True"
                                                     Height="8"
                                                     Margin="0,18,0,0"
                                                     Foreground="{StaticResource Brush.Accent}"
                                                     Background="#1E293B"
                                                     BorderThickness="0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="学习计划">
                <DockPanel Margin="0,10,0,0">
                    <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Button Content="生成 AI 学习计划" Command="{Binding GenerateStudyPlanCommand}" />
                    </WrapPanel>
                    <Grid MinHeight="280">
                        <TextBox VerticalAlignment="Stretch"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding StudyPlanText, Mode=OneWay}"
                                 IsReadOnly="True" />
                        <Border Background="#E60B1220"
                                Visibility="{Binding StudyPlanOutputBusy, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Margin="28"
                                        MaxWidth="440">
                                <TextBlock Text="{Binding StudyPlanOutputBusyMessage}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.Accent}" />
                                <ProgressBar IsIndeterminate="True"
                                             Height="8"
                                             Margin="0,18,0,0"
                                             Foreground="{StaticResource Brush.Accent}"
                                             Background="#1E293B"
                                             BorderThickness="0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
