<Window x:Class="AiSmartDrill.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AiSmartDrill.App.ViewModels"
        xmlns:cfg="clr-namespace:AiSmartDrill.App.Drill.Ai.Config"
        xmlns:conv="clr-namespace:AiSmartDrill.App.Converters"
        mc:Ignorable="d"
        Title="AI 智能题库与刷题系统"
        Height="760"
        Width="1180"
        Closed="MainWindow_OnClosed">
    <Window.Resources>
        <conv:OptionsJsonToDisplayConverter x:Key="OptionsJsonDisplayConverter" />
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="MutedHintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        </Style>
        <Style x:Key="ExamDomainPickerButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Grid MinWidth="320">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding DataContext.ExamDomainPickerCaption, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource MutedHintTextStyle}"
                                               Text="{Binding DataContext.ExamSelectedDomainsSummary, RelativeSource={RelativeSource AncestorType=Window}}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Margin="14,0,0,0"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Symbol"
                                           FontSize="14"
                                           Text="▾" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Brush.SurfaceElevated}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ExamDomainOptionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="OptionBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{DynamicResource Brush.InputBackground}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="9">
                            <DockPanel LastChildFill="True">
                                <Border x:Name="Indicator"
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        CornerRadius="8"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource Brush.BorderStrong}"
                                        BorderThickness="1" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OptionBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OptionBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter TargetName="OptionBorder" Property="Background" Value="{DynamicResource Brush.SurfaceElevated}" />
                                <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource Brush.Accent}" />
                                <Setter TargetName="Indicator" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ExamTrueButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource Brush.InputBackground}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.ExamUserAnswer, RelativeSource={RelativeSource AncestorType=Window}}" Value="对">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ExamFalseButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource Brush.InputBackground}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.ExamUserAnswer, RelativeSource={RelativeSource AncestorType=Window}}" Value="错">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <DockPanel Margin="22">
        <Border DockPanel.Dock="Top"
                Padding="18"
                CornerRadius="10"
                Background="{DynamicResource Brush.HeaderBarBackground}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="120" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Text="AI 智能题库与刷题系统" />
                <WrapPanel Grid.Row="0"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Margin="18,0,0,0">
                    <Label Content="AI 模型" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox Width="280"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center"
                              ToolTip="{Binding SelectedAiModelProfile.DisplayLabel}"
                              ItemsSource="{Binding AiModelProfileOptions}"
                              SelectedItem="{Binding SelectedAiModelProfile, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type cfg:DoubaoModelProfileListItem}">
                                <TextBlock Text="{Binding DisplayLabel}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource Brush.Text}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="＋"
                            ToolTip="增加模型"
                            Padding="6,4"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Command="{Binding AddAiModelProfileCommand}" />
                    <CheckBox Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              Content="按日出/日落自动主题"
                              IsChecked="{Binding UseSunAutoTheme, Mode=TwoWay}"
                              IsEnabled="{Binding SunScheduleFeatureEnabled}" />
                    <Button Command="{Binding ToggleThemeCommand}"
                            ToolTip="{Binding ThemeToggleToolTip}"
                            Padding="8,6"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <Grid Width="22" Height="22">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE706;"
                                       FontSize="16"
                                       Foreground="{DynamicResource Brush.Text}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowSunGlyph, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE708;"
                                       FontSize="16"
                                       Foreground="{DynamicResource Brush.Text}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowMoonGlyph, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                    </Button>
                    <TextBlock VerticalAlignment="Center"
                               Opacity="0.9"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding StatusMessage}"
                               MaxWidth="320"
                               Margin="0,0,0,8" />
                </WrapPanel>
                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Stretch">
                    <TextBlock FontSize="11"
                               Opacity="0.85"
                               Text="{Binding SunLocationHint}"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="{Binding SunSummaryLine}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Margin="0,6,0,0"
                                HorizontalAlignment="Left"
                                Visibility="{Binding ShowSunTimeline, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="400" Height="14" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Rectangle Fill="{DynamicResource Brush.Text}"
                                               Opacity="0.28"
                                               Width="{Binding SunBarNight1Width}"
                                               Height="12"
                                               RadiusX="1"
                                               RadiusY="1" />
                                    <Rectangle Fill="{DynamicResource Brush.Accent}"
                                               Opacity="0.55"
                                               Width="{Binding SunBarDayWidth}"
                                               Height="12"
                                               RadiusX="1"
                                               RadiusY="1" />
                                    <Rectangle Fill="{DynamicResource Brush.Text}"
                                               Opacity="0.28"
                                               Width="{Binding SunBarNight2Width}"
                                               Height="12"
                                               RadiusX="1"
                                               RadiusY="1" />
                                </StackPanel>
                                <Canvas Width="400" Height="14" IsHitTestVisible="False">
                                    <Rectangle Canvas.Left="{Binding SunIndicatorOffset}"
                                               Width="2"
                                               Height="14"
                                               Fill="#FFFF7040" />
                                </Canvas>
                            </Grid>
                            <TextBlock Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       FontFamily="Consolas,Courier New"
                                       Foreground="{DynamicResource Brush.Text}"
                                       Text="{Binding HeaderClockText}" />
                        </StackPanel>
                        <TextBlock MaxWidth="900"
                                   HorizontalAlignment="Left"
                                   Margin="0,4,0,0"
                                   FontSize="10"
                                   Opacity="0.75"
                                   TextAlignment="Left"
                                   TextWrapping="Wrap"
                                   Text="色条：午夜→日出（浅）→白昼（主题色）→日落→午夜；竖线为当前本机时刻。" />
                    </StackPanel>
                    <TextBlock Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource Brush.Accent}"
                               TextWrapping="Wrap"
                               Visibility="{Binding ShowSunScheduleMessage, Converter={StaticResource BoolToVisibility}}"
                               Text="{Binding SunPhaseHint}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabControl">
            <TabItem Header="题库管理">
                <DockPanel Margin="0,12,0,0">
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource SectionCardStyle}">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      MinHeight="40">
                            <WrapPanel>
                            <Label Content="题型" VerticalAlignment="Center" />
                            <ComboBox Width="120" ItemsSource="{Binding TypeFilterOptions}" SelectedItem="{Binding SelectedTypeFilter}" />
                            <Label Margin="12,0,0,0" Content="难度" VerticalAlignment="Center" />
                            <ComboBox Width="120" ItemsSource="{Binding DifficultyFilterOptions}" SelectedItem="{Binding SelectedDifficultyFilter}" />
                            <Label Margin="12,0,0,0" Content="领域" VerticalAlignment="Center" />
                            <ComboBox Width="150" ItemsSource="{Binding DomainFilterOptions}" SelectedItem="{Binding SelectedDomainFilter}" />
                            <Button Margin="8,0,0,0" Content="刷新题库" Command="{Binding RefreshBankCommand}" Click="RefreshBankButton_OnClick" />
                            <Button Margin="8,0,0,0" Content="新建题目" Command="{Binding NewQuestionCommand}" />
                            <Button Margin="8,0,0,0" Content="删除题目" Command="{Binding DeleteQuestionCommand}" />
                            </WrapPanel>
                        </ScrollViewer>
                    </Border>

                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      MinHeight="44">
                            <WrapPanel Orientation="Horizontal">
                            <Label Content="AI 模板" VerticalAlignment="Center" />
                            <ComboBox Width="150"
                                      Margin="6,0,12,0"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding BankAiTemplateOptions}"
                                      SelectedItem="{Binding SelectedBankAiTemplate}" />
                            <Label Content="生成数量" VerticalAlignment="Center" />
                            <TextBox Width="52"
                                     Margin="6,0,12,0"
                                     VerticalAlignment="Center"
                                     Text="{Binding BankAiGenCount, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="AI 按模板生成并入库"
                                    MinWidth="168"
                                    Padding="12,8"
                                    VerticalAlignment="Center"
                                    Command="{Binding GenerateBankQuestionsFromAiCommand}"
                                    IsEnabled="{Binding CanUseBankAiGen}" />
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Opacity="0.85"
                                       TextWrapping="Wrap"
                                       MaxWidth="420"
                                       Text="领域、难度、题型与「刷新题库」左侧筛选一致（题型选「全部」时用「AI 模板」）；难度选「全部」时每批随机简单/中等/困难。与右侧编辑器无关。生成多题时自动分批请求并逐批入库，减轻超时。模型须返回 JSON 数组（与导入格式一致）。" />
                            </WrapPanel>
                        </ScrollViewer>
                        <Border Margin="0,8,0,0"
                                Padding="12,10"
                                CornerRadius="4"
                                Background="{DynamicResource Brush.Surface}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                Visibility="{Binding IsBankAiGenerating, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <Button DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Padding="12,6"
                                            VerticalAlignment="Top"
                                            Content="取消请求"
                                            Command="{Binding CancelActiveAiRequestCommand}" />
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Accent}"
                                               Text="{Binding BankAiProgressPhase}"
                                               TextWrapping="Wrap" />
                                </DockPanel>
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="13"
                                           Text="{Binding BankAiProgressStatsLine}"
                                           TextWrapping="Wrap" />
                                <ProgressBar Height="10"
                                             Margin="0,10,0,0"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding BankAiProgressPercent}"
                                             Foreground="{DynamicResource Brush.Accent}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="11"
                                           Opacity="0.75"
                                           Text="下方细条：当前批次正在请求模型…"
                                           Visibility="{Binding BankAiBatchRequestActive, Converter={StaticResource BoolToVisibility}}" />
                                <ProgressBar Height="4"
                                             Margin="0,4,0,0"
                                             Foreground="{DynamicResource Brush.Accent}"
                                             IsIndeterminate="{Binding BankAiBatchRequestActive}"
                                             Visibility="{Binding BankAiBatchRequestActive, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" MinWidth="200" />
                            <ColumnDefinition Width="440" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource SectionCardStyle}"
                                Margin="0,0,16,0">
                        <DataGrid x:Name="BankQuestionsDataGrid"
                                  ItemsSource="{Binding BankQuestions}"
                                  SelectedItem="{Binding SelectedBankQuestion}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  LoadingRow="BankQuestionsDataGrid_OnLoadingRow"
                                  CellEditEnding="BankQuestionsDataGrid_OnCellEditEnding">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id"
                                                    Binding="{Binding Id}"
                                                    Width="60"
                                                    IsReadOnly="True" />
                                <DataGridTextColumn Header="题型"
                                                    Binding="{Binding Type}"
                                                    Width="90"
                                                    IsReadOnly="True" />
                                <DataGridTextColumn Header="难度"
                                                    Binding="{Binding Difficulty}"
                                                    Width="90"
                                                    IsReadOnly="True" />
                                <DataGridTextColumn Header="分类标签"
                                                    Binding="{Binding TopicTags, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                    Width="200"
                                                    IsReadOnly="False" />
                                <DataGridTextColumn Header="选项（明细）"
                                                    Binding="{Binding OptionsJson, Converter={StaticResource OptionsJsonDisplayConverter}}"
                                                    Width="280"
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="标准答案"
                                                    Binding="{Binding StandardAnswer}"
                                                    Width="160"
                                                    IsReadOnly="True" />
                                <DataGridTextColumn Header="题干"
                                                    Binding="{Binding Stem}"
                                                    Width="380"
                                                    MinWidth="160"
                                                    IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource SectionCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontWeight="SemiBold"
                                           Text="题目编辑器"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Margin="0,0,8,0"
                                            MinWidth="100"
                                            Padding="12,6"
                                            Content="AI 出题"
                                            ToolTip="仅在「新建题目」（左侧未选中题目）时可用。上方为进度与动画；成功后仅弹出简短提示，详情见 AI 日志。"
                                            Command="{Binding FillEditorQuestionFromAiCommand}" />
                                    <CheckBox Margin="0,0,8,0"
                                              VerticalAlignment="Center"
                                              Content="提示词带标签"
                                              IsChecked="{Binding EditorAiSendTopicTagsToPrompt, Mode=TwoWay}"
                                              ToolTip="勾选时把下方「分类标签」「检索关键词」一并写入 AI 提示；不勾选则仅按领域、题型与难度出题，填入的标签以模型返回为准。" />
                                    <Button MinWidth="88"
                                            Padding="12,6"
                                            Content="保存题目"
                                            Command="{Binding SaveQuestionCommand}" />
                                </StackPanel>
                            </Grid>
                            <Border Grid.Row="1"
                                    Margin="0,0,0,8"
                                    Padding="8,6"
                                    CornerRadius="4"
                                    Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    Visibility="{Binding IsEditorAiFillBusy, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <Button DockPanel.Dock="Right"
                                                Margin="8,0,0,0"
                                                Padding="12,6"
                                                VerticalAlignment="Top"
                                                Content="取消请求"
                                                Command="{Binding CancelActiveAiRequestCommand}" />
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Accent}"
                                                   Text="{Binding EditorAiProgressPhase}"
                                                   TextWrapping="Wrap" />
                                    </DockPanel>
                                    <ProgressBar Height="6"
                                                 Margin="0,6,0,0"
                                                 IsIndeterminate="True"
                                                 Foreground="{DynamicResource Brush.Accent}" />
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,0,6,0">
                            <StackPanel>
                            <Label Content="题型" />
                            <ComboBox ItemsSource="{Binding EditorTypeOptions}" SelectedItem="{Binding EditorType}" />
                            <Label Content="难度" />
                            <ComboBox ItemsSource="{Binding EditorDifficultyOptions}" SelectedItem="{Binding EditorDifficulty}" />
                            <Label Content="领域" />
                            <ComboBox ItemsSource="{Binding EditorDomainOptions}" SelectedItem="{Binding EditorDomain}" />
                            <Label Content="题干" />
                            <TextBox Height="90" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding EditorStem, UpdateSourceTrigger=PropertyChanged}" />
                            <Label Content="选项 JSON（客观题选项列表）" />
                            <TextBox Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding EditorOptionsJson, UpdateSourceTrigger=PropertyChanged}" />
                            <Label FontWeight="SemiBold" Content="标准答案（可编辑）" />
                            <TextBlock Margin="0,0,0,4"
                                       FontSize="11"
                                       Opacity="0.85"
                                       TextWrapping="Wrap"
                                       Text="单选填选项键如 A；多选如 A,C；判断填 对 或 错；简答填分号分隔关键词；填空题为判分用正则表达式。修改后请点击「保存题目」。" />
                            <TextBox MinHeight="56"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding EditorStandardAnswer, UpdateSourceTrigger=PropertyChanged}" />
                            <Label Content="模块 / 大标签（TopicTags，逗号分隔）" />
                            <TextBlock Margin="0,0,0,4"
                                       FontSize="11"
                                       Opacity="0.8"
                                       TextWrapping="Wrap"
                                       Text="点击下方词可追加到本框；也可在左侧表格「分类标签」列直接修改，失焦后自动入库。" />
                            <ScrollViewer MaxHeight="120"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding TopicTagPresetOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,6,6"
                                                    Padding="8,4"
                                                    Content="{Binding}"
                                                    Command="{Binding DataContext.AppendTopicTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBox Margin="0,4,0,0"
                                     Text="{Binding EditorTopicTags, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="36"
                                     VerticalScrollBarVisibility="Auto" />
                            <Label Content="细知识点（KnowledgeTags，逗号分隔）" />
                            <TextBlock Margin="0,0,0,4"
                                       FontSize="11"
                                       Opacity="0.8"
                                       TextWrapping="Wrap"
                                       Text="填写可教可测的考点短语；勿重复填写领域名（领域以上方「领域」为准）。" />
                            <TextBox Text="{Binding EditorKnowledgeTags, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="36"
                                     VerticalScrollBarVisibility="Auto" />
                            <Label Content="主知识点（与上框中一项一致，推荐严格匹配）" />
                            <TextBox Text="{Binding EditorPrimaryKnowledgePoint, UpdateSourceTrigger=PropertyChanged}" />
                            <Label Content="检索关键词（逗号/分号分隔）" />
                            <TextBox Text="{Binding EditorTopicKeywords, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            </ScrollViewer>
                        </Grid>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="考试 / 刷题">
                <DockPanel Margin="0,10,0,0">
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource SectionCardStyle}"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          MinHeight="44">
                            <WrapPanel ItemHeight="40">
                                <Label Content="题量" VerticalAlignment="Center" />
                                <TextBox Width="70" Height="32" VerticalAlignment="Center" Text="{Binding ExamQuestionCount, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Margin="12,0,0,0" Content="时长(分)" VerticalAlignment="Center" />
                                <TextBox Width="70" Height="32" VerticalAlignment="Center" Text="{Binding ExamMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="10,0,0,0" Content="随机组卷并开始" Command="{Binding StartExamCommand}" MinWidth="140" Height="35" Padding="12,6" />
                                <Button Margin="8,0,0,0" Content="交卷" Command="{Binding SubmitExamCommand}" MinWidth="88" Height="35" Padding="12,6" />
                                <Button Margin="8,0,0,0" Content="取消做题" Command="{Binding CancelExamCommand}" MinWidth="88" Height="35" Padding="12,6" />
                                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding LastScoreText, StringFormat=最近成绩：{0}}" />
                            </WrapPanel>
                            </ScrollViewer>
                            <Grid Margin="0,10,0,0">
                                <ToggleButton x:Name="ExamDomainPickerToggle"
                                              Style="{StaticResource ExamDomainPickerButtonStyle}" />
                                <Popup x:Name="ExamDomainPickerPopup"
                                       PlacementTarget="{Binding ElementName=ExamDomainPickerToggle}"
                                       Placement="Bottom"
                                       VerticalOffset="10"
                                       AllowsTransparency="True"
                                       StaysOpen="False"
                                       Opened="ExamDomainPickerPopup_OnOpened"
                                       IsOpen="{Binding IsChecked, ElementName=ExamDomainPickerToggle, Mode=TwoWay}">
                                    <Border Width="{Binding ActualWidth, ElementName=ExamDomainPickerToggle}"
                                            Padding="16"
                                            Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="选择领域" />
                                            <TextBlock Margin="0,4,0,12"
                                                       Style="{StaticResource MutedHintTextStyle}"
                                                       Text="展开后勾选一个或多个领域；如果不选，则仍按题库页当前领域筛选组卷。" />
                                            <ItemsControl ItemsSource="{Binding ExamDomainPicks}" AlternationCount="64">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:ExamDomainPickVm}">
                                                        <CheckBox Width="136"
                                                                  Style="{StaticResource ExamDomainOptionCheckBoxStyle}"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding DisplayName}"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top"
                            Padding="16,14"
                            CornerRadius="10"
                            Background="{DynamicResource Brush.CountdownStripBackground}"
                            BorderBrush="{DynamicResource Brush.Accent}"
                            BorderThickness="1"
                            Margin="0,0,0,14">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Accent}" Text="倒计时（秒）" />
                            <TextBlock DockPanel.Dock="Left" Margin="10,0,0,0" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}" Text="{Binding ExamRemainingSeconds}" />
                            <TextBlock DockPanel.Dock="Right" Opacity="0.85" Text="{Binding ExamProgressLabel}" TextWrapping="Wrap" MaxWidth="420" TextAlignment="Right" />
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid MinHeight="200">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,14">
                            <TextBlock FontWeight="SemiBold" Text="{Binding ExamTypeText, StringFormat=题型：{0}}" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding ExamDifficultyText, StringFormat=难度：{0}}" />
                            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" FontSize="16" Text="{Binding ExamStem}" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                MaxHeight="280"
                                Padding="16"
                                CornerRadius="10"
                                Background="{DynamicResource Brush.Surface}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                Margin="0,0,0,14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock TextWrapping="Wrap" Opacity="0.9" Text="{Binding ExamOptionsDisplay}" />
                            </ScrollViewer>
                        </Border>

                        <DockPanel Grid.Row="2" LastChildFill="True" Margin="0,2,0,0">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="上一题" Command="{Binding ExamPrevCommand}" />
                                <Button Content="下一题" Command="{Binding ExamNextCommand}" />
                            </StackPanel>
                            <StackPanel>
                                <Label Content="你的答案" />
                                <ItemsControl Margin="0,0,0,8"
                                              Visibility="{Binding ExamShowMcqSinglePanel, Converter={StaticResource BoolToVisibility}}"
                                              ItemsSource="{Binding ExamMcqOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ExamOptionItemVm}">
                                            <Button MinWidth="120"
                                                    Margin="0,0,10,8"
                                                    Padding="12,8"
                                                    Content="{Binding Caption}"
                                                    Style="{StaticResource ExamOptionButtonStyle}"
                                                    Command="{Binding DataContext.ExamPickSingleOptionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl Margin="0,0,0,8"
                                              Visibility="{Binding ExamShowMcqMultiPanel, Converter={StaticResource BoolToVisibility}}"
                                              ItemsSource="{Binding ExamMcqOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ExamOptionItemVm}">
                                            <Button MinWidth="120"
                                                    Margin="0,0,10,8"
                                                    Padding="12,8"
                                                    Content="{Binding Caption}"
                                                    Style="{StaticResource ExamOptionButtonStyle}"
                                                    Command="{Binding DataContext.ExamToggleMultiOptionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <UniformGrid Margin="0,0,0,8"
                                             Rows="1"
                                             Columns="2"
                                             Width="252"
                                             HorizontalAlignment="Left"
                                             Visibility="{Binding ExamShowTrueFalsePanel, Converter={StaticResource BoolToVisibility}}">
                                    <Button Margin="0,0,6,0"
                                            Padding="14,10"
                                            Content="对"
                                            Style="{StaticResource ExamTrueButtonStyle}"
                                            Command="{Binding ExamPickTrueCommand}" />
                                    <Button Margin="6,0,0,0"
                                            Padding="14,10"
                                            Content="错"
                                            Style="{StaticResource ExamFalseButtonStyle}"
                                            Command="{Binding ExamPickFalseCommand}" />
                                </UniformGrid>
                                <TextBox MinHeight="34"
                                         Visibility="{Binding ExamShowTextAnswerPanel, Converter={StaticResource BoolToVisibility}}"
                                         Text="{Binding ExamUserAnswer, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </DockPanel>

                        <StackPanel Grid.Row="3" Margin="0,16,0,0">
                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="不会，问AI"
                                        MinWidth="132"
                                        Padding="12,8"
                                        Command="{Binding AskAiAboutCurrentExamQuestionCommand}"
                                        IsEnabled="{Binding CanAskExamAi}" />
                                <TextBlock Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Opacity="0.85"
                                           Text="将本题与当前作答发送给模型，返回解析" />
                            </WrapPanel>
                            <GroupBox Header="AI 解析">
                                <Grid MinHeight="120" MaxHeight="260">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Margin="0,0,0,6">
                                        <TextBlock Text="【要点】"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   Opacity="0.85" />
                                        <TextBlock Text="{Binding ExamAiConclusionText, Mode=OneWay}"
                                                   TextWrapping="Wrap"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Accent}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="【详解】"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   Opacity="0.85" />
                                    </StackPanel>
                                    <TextBox Grid.Row="1"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding ExamAiExplanationText, Mode=OneWay}"
                                             IsReadOnly="True" />
                                    <Border Grid.RowSpan="2"
                                            Background="{DynamicResource Brush.OverlayScrim}"
                                            Visibility="{Binding IsExamAiExplainBusy, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                                            <TextBlock Text="正在请求 AI…"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.Accent}" />
                                            <ProgressBar IsIndeterminate="True"
                                                         Height="8"
                                                         Width="200"
                                                         Margin="0,14,0,0"
                                                         BorderThickness="0" />
                                            <Button Margin="0,16,0,0"
                                                    Padding="16,8"
                                                    HorizontalAlignment="Center"
                                                    Content="取消请求"
                                                    Command="{Binding CancelActiveAiRequestCommand}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </Grid>
                    </ScrollViewer>
                    </Border>
                </DockPanel>
            </TabItem>

            <TabItem Header="错题本 / AI">
                <DockPanel Margin="0,10,0,0">
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <!-- 单行横向滚动，避免窗口变窄时操作按钮被挤到视野外 -->
                        <ScrollViewer Grid.Row="0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      MinHeight="44"
                                      Padding="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="刷新错题本"
                                        Command="{Binding RefreshWrongBookCommand}"
                                        Margin="0,0,10,0"
                                        MinHeight="38"
                                        MinWidth="150"
                                        Padding="14,10" />
                                <Button Content="错题再练（组卷）"
                                        Command="{Binding StartWrongBookPracticeCommand}"
                                        Margin="0,0,10,0"
                                        MinHeight="38"
                                        MinWidth="150"
                                        Padding="14,10" />
                                <Button Content="AI 错题解析（已勾选）"
                                        Command="{Binding AiTutorAnalyzeWrongCommand}"
                                        Margin="0,0,10,0"
                                        MinHeight="38"
                                        MinWidth="150"
                                        Padding="14,10" />
                                <Button Content="AI 题目推荐"
                                        Command="{Binding RecommendCommand}"
                                        Margin="0,0,10,0"
                                        MinHeight="38"
                                        MinWidth="150"
                                        Padding="14,10" />
                                <Button Content="用推荐题开始考试"
                                        Command="{Binding StartExamFromRecommendationCommand}"
                                        Margin="0,0,10,0"
                                        MinHeight="38"
                                        MinWidth="150"
                                        Padding="14,10" />
                                <Grid>
                                    <ToggleButton x:Name="WrongBookAiLogToggle"
                                                  MinWidth="128"
                                                  Padding="14,8"
                                                  VerticalAlignment="Top"
                                                  Content="查看 AI 日志" />
                                    <Popup PlacementTarget="{Binding ElementName=WrongBookAiLogToggle}"
                                           Placement="Bottom"
                                           VerticalOffset="10"
                                           AllowsTransparency="True"
                                           StaysOpen="False"
                                           IsOpen="{Binding IsChecked, ElementName=WrongBookAiLogToggle, Mode=TwoWay}">
                                        <Border Width="460"
                                                MaxWidth="560"
                                                Padding="16"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="调用日志（调试）" />
                                                <TextBox Grid.Row="1"
                                                         Margin="0,10,0,0"
                                                         MinHeight="220"
                                                         MaxHeight="320"
                                                         Text="{Binding AiPipelineLog, Mode=OneWay}"
                                                         IsReadOnly="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         FontFamily="Consolas"
                                                         FontSize="11" />
                                            </Grid>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                        <WrapPanel Grid.Row="1" Margin="0,6,0,0" ItemHeight="38">
                            <Label Content="领域筛选" VerticalAlignment="Center" />
                            <ComboBox Width="168"
                                      Margin="6,0,10,0"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding WrongBookDomainFilterOptions}"
                                      SelectedItem="{Binding WrongBookDomainFilter}" />
                            <Button Content="{Binding WrongBookSelectAllInFilterCaption}"
                                    Command="{Binding WrongBookSelectAllInFilterCommand}"
                                    Margin="0,0,12,0"
                                    MinHeight="34"
                                    MinWidth="112"
                                    Padding="12,8"
                                    VerticalAlignment="Center" />
                            <CheckBox VerticalAlignment="Center"
                                      Content="保存错题详情"
                                      IsChecked="{Binding PersistWrongBookDetails}" />
                        </WrapPanel>
                    </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="440" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="错题列表（含错答 / 标答）" Margin="0,0,16,0">
                            <DataGrid ItemsSource="{Binding WrongBookRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeColumns="True"
                                      HeadersVisibility="Column"
                                      ColumnHeaderHeight="40"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="84" MinWidth="84" MaxWidth="84">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="76"
                                                       Text="解析"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <CheckBox HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsThreeState="False">
                                                    <CheckBox.LayoutTransform>
                                                        <ScaleTransform ScaleX="1.45" ScaleY="1.45" />
                                                    </CheckBox.LayoutTransform>
                                                </CheckBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="88" MinWidth="88" MaxWidth="88">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="80"
                                                       Text="领域"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock Text="{Binding DomainDisplay}"
                                                           TextWrapping="Wrap"
                                                           Width="80"
                                                           MaxHeight="96"
                                                           ToolTip="{Binding DomainDisplay}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="76" MinWidth="76" MaxWidth="76">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="68"
                                                       Text="题型"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock Text="{Binding TypeDisplay}"
                                                           TextWrapping="Wrap"
                                                           Width="68"
                                                           MaxHeight="96"
                                                           ToolTip="{Binding TypeDisplay}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="220" MinWidth="220" MaxWidth="220">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="200"
                                                       Text="题干"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock Text="{Binding Stem}"
                                                           TextWrapping="Wrap"
                                                           Width="200"
                                                           MaxHeight="120"
                                                           ToolTip="{Binding Stem}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="280" MinWidth="220" MaxWidth="400">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="240"
                                                       Text="选项（明细）"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock Text="{Binding OptionsDisplay}"
                                                           TextWrapping="Wrap"
                                                           Width="260"
                                                           MaxHeight="140"
                                                           ToolTip="{Binding OptionsDisplay}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="168" MinWidth="168" MaxWidth="168">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="150"
                                                       Text="你的错答"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock Text="{Binding WrongAnswerDisplay}"
                                                           TextWrapping="Wrap"
                                                           Width="150"
                                                           MaxHeight="120"
                                                           ToolTip="{Binding WrongAnswerDisplay}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="148" MinWidth="148" MaxWidth="148">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="132"
                                                       Text="标准答案"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock Text="{Binding StandardAnswerDisplay}"
                                                           TextWrapping="Wrap"
                                                           Width="132"
                                                           MaxHeight="120"
                                                           ToolTip="{Binding StandardAnswerDisplay}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="52" MinWidth="52" MaxWidth="52">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="44"
                                                       Text="错次"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock Text="{Binding WrongCount}"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="128" MinWidth="128" MaxWidth="128">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="118"
                                                       Text="最近错误"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock Text="{Binding LastWrongAtDisplay}"
                                                           TextWrapping="Wrap"
                                                           Width="118"
                                                           MaxHeight="96"
                                                           ToolTip="{Binding LastWrongAtDisplay}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="76" MinWidth="76" MaxWidth="76">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="68"
                                                       Text="已重做"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Accent}"
                                                           Text="{Binding RedoTagDisplay}"
                                                           ToolTip="{Binding RedoTagToolTip}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="84" MinWidth="84" MaxWidth="84">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Width="72"
                                                       Text="操作"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:WrongBookRowVm}">
                                                <Button MinHeight="32"
                                                        Padding="10,6"
                                                        Content="删除"
                                                        Command="{Binding DataContext.DeleteWrongBookEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Column="1" Header="AI 输出（解析/推荐）">
                            <Grid MinHeight="280">
                                <TextBox VerticalAlignment="Stretch"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding AiOutputText, Mode=OneWay}"
                                         IsReadOnly="True" />
                                <Border Background="{DynamicResource Brush.OverlayScrim}"
                                        Visibility="{Binding AiMainOutputBusy, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Margin="28"
                                                MaxWidth="440">
                                        <TextBlock Text="{Binding AiMainOutputBusyMessage}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Accent}" />
                                        <ProgressBar IsIndeterminate="True"
                                                     Height="8"
                                                     Margin="0,18,0,0"
                                                     BorderThickness="0" />
                                        <Button Margin="0,16,0,0"
                                                Padding="16,8"
                                                HorizontalAlignment="Center"
                                                Content="取消请求"
                                                Command="{Binding CancelActiveAiRequestCommand}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="学习计划">
                <DockPanel Margin="0,10,0,0">
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource SectionCardStyle}">
                    <WrapPanel>
                        <Button Content="生成 AI 学习计划" Command="{Binding GenerateStudyPlanCommand}" />
                        <Button Content="保存到历史" Command="{Binding SaveStudyPlanCommand}" />
                        <Button Content="刷新历史" Command="{Binding RefreshStudyPlanHistoryCommand}" />
                    </WrapPanel>
                    </Border>
                    <Border Style="{StaticResource SectionCardStyle}">
                    <Grid MinHeight="320">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Style="{StaticResource PanelTitleStyle}" Text="历史记录" />
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource MutedHintTextStyle}"
                                           Text="保存后会记录时间和主题，点选左侧历史即可回看。" />
                            </StackPanel>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding StudyPlanHistories}"
                                      SelectedItem="{Binding SelectedStudyPlanHistory, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="时间"
                                                        Binding="{Binding CreatedAtLocalTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                        Width="128" />
                                    <DataGridTextColumn Header="主题"
                                                        Binding="{Binding Theme}"
                                                        Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Style="{StaticResource PanelTitleStyle}" Text="{Binding StudyPlanTitle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource MutedHintTextStyle}"
                                           Text="{Binding StudyPlanTheme}" />
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     VerticalAlignment="Stretch"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding StudyPlanText, Mode=OneWay}"
                                     IsReadOnly="True" />
                        </Grid>
                        <Border Background="{DynamicResource Brush.OverlayScrim}"
                                Visibility="{Binding StudyPlanOutputBusy, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Margin="28"
                                        MaxWidth="440">
                                <TextBlock Text="{Binding StudyPlanOutputBusyMessage}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.Accent}" />
                                <ProgressBar IsIndeterminate="True"
                                             Height="8"
                                             Margin="0,18,0,0"
                                             BorderThickness="0" />
                                <Button Margin="0,16,0,0"
                                        Padding="16,8"
                                        HorizontalAlignment="Center"
                                        Content="取消请求"
                                        Command="{Binding CancelActiveAiRequestCommand}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    </Border>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
