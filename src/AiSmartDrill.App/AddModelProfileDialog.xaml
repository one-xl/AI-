<Window x:Class="AiSmartDrill.App.AddModelProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="增加 AI 模型"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.Text}">
    <StackPanel Margin="24">
        <TextBlock Text="显示名称（可选）" Margin="0,0,0,4" />
        <TextBox x:Name="TbDisplayName" Margin="0,0,0,12" />

        <TextBlock Text="API Key *" Margin="0,0,0,4" />
        <TextBox x:Name="TbApiKey" Margin="0,0,0,12" />

        <TextBlock Text="接入点 / 模型名 (ModelName) *" Margin="0,0,0,4" />
        <TextBox x:Name="TbModelName" Margin="0,0,0,12" />

        <TextBlock Text="Base URL *" Margin="0,0,0,4" />
        <TextBox x:Name="TbBaseUrl" Margin="0,0,0,12" />

        <CheckBox x:Name="CbEnableThinking"
                  Content="启用深度思考"
                  IsChecked="True"
                  Margin="0,0,0,20" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Padding="20,8" Margin="0,0,12,0" Click="OnCancel" />
            <Button Content="保存" Padding="20,8" Click="OnSave" />
        </StackPanel>
    </StackPanel>
</Window>
