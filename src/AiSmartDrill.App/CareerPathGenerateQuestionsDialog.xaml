<Window x:Class="AiSmartDrill.App.CareerPathGenerateQuestionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="生成技能点题目"
        Width="620"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.Text}">
    <StackPanel Margin="24">
        <TextBlock Text="题库中没有命中当前技能包知识点的题目。可直接按这些知识点生成一批新题并写入题库，然后继续刷题。"
                   TextWrapping="Wrap" />

        <Grid Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="归入领域" />
            <ComboBox x:Name="CbDomain" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="领域现状" />
            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Text="{Binding DomainStateText}" TextWrapping="Wrap" />

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="生成数量" />
            <TextBox x:Name="TbCount" Grid.Row="2" Grid.Column="1" Width="96" HorizontalAlignment="Left" Text="{Binding DefaultCount}" />

            <UniformGrid Grid.Row="3" Grid.Column="1" Columns="2" Margin="0,0,0,0">
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Margin="0,0,0,4" Text="题型" />
                    <ComboBox x:Name="CbType" SelectedIndex="0">
                        <ComboBoxItem Content="单选" />
                        <ComboBoxItem Content="多选" />
                        <ComboBoxItem Content="判断" />
                        <ComboBoxItem Content="简答" />
                        <ComboBoxItem Content="填空" />
                    </ComboBox>
                </StackPanel>
                <StackPanel>
                    <TextBlock Margin="0,0,0,4" Text="难度" />
                    <ComboBox x:Name="CbDifficulty" SelectedIndex="0">
                        <ComboBoxItem Content="全部" />
                        <ComboBoxItem Content="简单" />
                        <ComboBoxItem Content="中等" />
                        <ComboBoxItem Content="困难" />
                    </ComboBox>
                </StackPanel>
            </UniformGrid>
        </Grid>

        <TextBlock Margin="0,18,0,6" Text="知识点来源" />
        <TextBox Text="{Binding SkillsPreview}"
                 Height="120"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" />

        <TextBlock Margin="0,10,0,0"
                   Opacity="0.78"
                   TextWrapping="Wrap"
                   Text="说明：系统会优先按技能点推断到现有领域；如果无法明确识别，则写入“未分类”，并通过 TopicTags / KnowledgeTags 保留细分归类。" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="取消" Padding="20,8" Margin="0,0,12,0" Click="OnCancel" />
            <Button Content="开始生成并入库" Padding="20,8" Click="OnSave" />
        </StackPanel>
    </StackPanel>
</Window>
