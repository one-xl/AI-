<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 现代暗色主题：略抬底色、降对比，减轻刺眼感 -->
    <SolidColorBrush x:Key="Brush.Background" Color="#171815" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#1F211D" />
    <SolidColorBrush x:Key="Brush.SurfaceElevated" Color="#272A25" />
    <SolidColorBrush x:Key="Brush.Text" Color="#E4E0D6" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#A8A297" />
    <SolidColorBrush x:Key="Brush.Border" Color="#34372F" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#484C43" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#7EB09B" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#F2F3F5" />

    <SolidColorBrush x:Key="Brush.InputBackground" Color="#1B1D19" />
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#4A4E45" />
    <SolidColorBrush x:Key="Brush.ComboHoverMain" Color="#242721" />
    <SolidColorBrush x:Key="Brush.ComboFocusMain" Color="#1A1C18" />
    <SolidColorBrush x:Key="Brush.ComboDropdownBackground" Color="#22241F" />
    <SolidColorBrush x:Key="Brush.ComboItemHover" Color="#2D312B" />
    <SolidColorBrush x:Key="Brush.ButtonBackground" Color="#232620" />
    <SolidColorBrush x:Key="Brush.ButtonHover" Color="#2C3029" />
    <SolidColorBrush x:Key="Brush.ButtonPressed" Color="#3A3E36" />
    <SolidColorBrush x:Key="Brush.ButtonHoverBorder" Color="#5A5E56" />

    <SolidColorBrush x:Key="Brush.TabPanelBackground" Color="#171815" />
    <SolidColorBrush x:Key="Brush.TabItemBackground" Color="#232620" />
    <SolidColorBrush x:Key="Brush.TabItemText" Color="#B7B1A6" />
    <SolidColorBrush x:Key="Brush.TabItemSelectedBackground" Color="#171815" />
    <SolidColorBrush x:Key="Brush.TabItemHoverBackground" Color="#2B2F28" />

    <SolidColorBrush x:Key="Brush.DataGridBackground" Color="#1B1D19" />
    <SolidColorBrush x:Key="Brush.DataGridRowAlt" Color="#20231E" />
    <SolidColorBrush x:Key="Brush.DataGridHeaderBackground" Color="#272A25" />
    <SolidColorBrush x:Key="Brush.DataGridCellSelected" Color="#34443E" />

    <SolidColorBrush x:Key="Brush.ListBackground" Color="#1B1D19" />
    <SolidColorBrush x:Key="Brush.ListItemHover" Color="#242721" />
    <SolidColorBrush x:Key="Brush.ListItemSelected" Color="#2E332D" />

    <SolidColorBrush x:Key="Brush.ProgressTrack" Color="#34372F" />
    <SolidColorBrush x:Key="Brush.OverlayScrim" Color="#CC171815" />

    <SolidColorBrush x:Key="Brush.CountdownStripBackground" Color="#1F2A24" />
    <SolidColorBrush x:Key="Brush.HeaderBarBackground" Color="#1F211D" />
    <SolidColorBrush x:Key="Brush.FooterBarBackground" Color="#1A1C18" />

    <!-- 未用主题色的原生控件（滚动条、菜单等）对齐暗底，避免大块亮白 -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#171815" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E4E0D6" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1F211D" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E4E0D6" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#2B2F28" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#383C34" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#141613" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#0E100D" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ScrollBarBrushKey}" Color="#272A25" />
</ResourceDictionary>
