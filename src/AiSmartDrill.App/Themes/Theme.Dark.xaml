<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 现代暗色主题：略抬底色、降对比，减轻刺眼感 -->
    <SolidColorBrush x:Key="Brush.Background" Color="#0E0E12" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#16161C" />
    <SolidColorBrush x:Key="Brush.SurfaceElevated" Color="#1E1E26" />
    <SolidColorBrush x:Key="Brush.Text" Color="#C8C8D0" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#8A8A94" />
    <SolidColorBrush x:Key="Brush.Border" Color="#2A2A32" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#3A3A44" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#4A8AD9" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#F2F3F5" />

    <SolidColorBrush x:Key="Brush.InputBackground" Color="#14141A" />
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#3B3B44" />
    <SolidColorBrush x:Key="Brush.ComboHoverMain" Color="#1C1C21" />
    <SolidColorBrush x:Key="Brush.ComboFocusMain" Color="#131316" />
    <SolidColorBrush x:Key="Brush.ComboDropdownBackground" Color="#1C1C21" />
    <SolidColorBrush x:Key="Brush.ComboItemHover" Color="#27272C" />
    <SolidColorBrush x:Key="Brush.ButtonBackground" Color="#1C1C21" />
    <SolidColorBrush x:Key="Brush.ButtonHover" Color="#27272C" />
    <SolidColorBrush x:Key="Brush.ButtonPressed" Color="#3B3B44" />
    <SolidColorBrush x:Key="Brush.ButtonHoverBorder" Color="#4B4B56" />

    <SolidColorBrush x:Key="Brush.TabPanelBackground" Color="#0E0E12" />
    <SolidColorBrush x:Key="Brush.TabItemBackground" Color="#16161C" />
    <SolidColorBrush x:Key="Brush.TabItemText" Color="#9A9AA4" />
    <SolidColorBrush x:Key="Brush.TabItemSelectedBackground" Color="#0E0E12" />
    <SolidColorBrush x:Key="Brush.TabItemHoverBackground" Color="#1E1E26" />

    <SolidColorBrush x:Key="Brush.DataGridBackground" Color="#14141A" />
    <SolidColorBrush x:Key="Brush.DataGridRowAlt" Color="#18181F" />
    <SolidColorBrush x:Key="Brush.DataGridHeaderBackground" Color="#1E1E26" />
    <SolidColorBrush x:Key="Brush.DataGridCellSelected" Color="#2A2F3A" />

    <SolidColorBrush x:Key="Brush.ListBackground" Color="#14141A" />
    <SolidColorBrush x:Key="Brush.ListItemHover" Color="#1C1C21" />
    <SolidColorBrush x:Key="Brush.ListItemSelected" Color="#27272C" />

    <SolidColorBrush x:Key="Brush.ProgressTrack" Color="#2A2A32" />
    <SolidColorBrush x:Key="Brush.OverlayScrim" Color="#CC0E0E12" />

    <SolidColorBrush x:Key="Brush.CountdownStripBackground" Color="#14141A" />
    <SolidColorBrush x:Key="Brush.HeaderBarBackground" Color="#16161C" />
    <SolidColorBrush x:Key="Brush.FooterBarBackground" Color="#14141A" />

    <!-- 未用主题色的原生控件（滚动条、菜单等）对齐暗底，避免大块亮白 -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0E0E12" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#C8C8D0" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#16161C" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#C8C8D0" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#24242C" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#2E2E38" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#121218" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#0A0A0E" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ScrollBarBrushKey}" Color="#1E1E26" />
</ResourceDictionary>
