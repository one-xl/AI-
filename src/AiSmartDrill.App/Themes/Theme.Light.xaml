    <SolidColorBrush x:Key="Brush.CountdownStripBackground" Color="#F1F1F4" />
    <SolidColorBrush x:Key="Brush.HeaderBarBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.FooterBarBackground" Color="#F1F1F4" />
</ResourceDictionary>
