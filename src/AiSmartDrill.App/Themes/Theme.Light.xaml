    <SolidColorBrush x:Key="Brush.TabItemHoverBackground" Color="#E4DDD0" />

    <SolidColorBrush x:Key="Brush.DataGridBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.DataGridRowAlt" Color="#F8F4EE" />
    <SolidColorBrush x:Key="Brush.DataGridHeaderBackground" Color="#F0ECE4" />
