    <SolidColorBrush x:Key="Brush.ButtonHover" Color="#F1F1F4" />
    <SolidColorBrush x:Key="Brush.ButtonPressed" Color="#DFDFE4" />
    <SolidColorBrush x:Key="Brush.ButtonHoverBorder" Color="#9898A0" />

    <SolidColorBrush x:Key="Brush.TabPanelBackground" Color="#F8F8FA" />
    <SolidColorBrush x:Key="Brush.TabItemBackground" Color="#F1F1F4" />
    <SolidColorBrush x:Key="Brush.TabItemText" Color="#3B3B44" />
    <SolidColorBrush x:Key="Brush.TabItemSelectedBackground" Color="#F8F8FA" />
    <SolidColorBrush x:Key="Brush.TabItemHoverBackground" Color="#DFDFE4" />

    <SolidColorBrush x:Key="Brush.DataGridBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.DataGridRowAlt" Color="#F8F8FA" />
    <SolidColorBrush x:Key="Brush.DataGridHeaderBackground" Color="#F1F1F4" />
    <SolidColorBrush x:Key="Brush.DataGridCellSelected" Color="#DFDFE4" />

    <SolidColorBrush x:Key="Brush.ListBackground" Color="#FFFFFF" />
