<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 现代浅色主题：柔和中性 + 蓝色强调 -->
    <SolidColorBrush x:Key="Brush.Background" Color="#F5F4EF" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFFDFC" />
    <SolidColorBrush x:Key="Brush.SurfaceElevated" Color="#F0ECE4" />
    <SolidColorBrush x:Key="Brush.Text" Color="#1F2329" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#6B7280" />
    <SolidColorBrush x:Key="Brush.Border" Color="#DDD5C7" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#C9BEAC" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#2F6F5F" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFF" />

    <SolidColorBrush x:Key="Brush.InputBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#C9BEAC" />
    <SolidColorBrush x:Key="Brush.ComboHoverMain" Color="#F0ECE4" />
