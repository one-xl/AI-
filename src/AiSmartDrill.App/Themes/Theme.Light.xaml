<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 现代浅色主题：柔和中性 + 蓝色强调 -->
    <SolidColorBrush x:Key="Brush.Background" Color="#F8F8FA" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.SurfaceElevated" Color="#F1F1F4" />
    <SolidColorBrush x:Key="Brush.Text" Color="#111114" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#6C6C76" />
    <SolidColorBrush x:Key="Brush.Border" Color="#DFDFE4" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#C8C8D0" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#2563EB" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFF" />

    <SolidColorBrush x:Key="Brush.InputBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#C8C8D0" />
    <SolidColorBrush x:Key="Brush.ComboHoverMain" Color="#F1F1F4" />
    <SolidColorBrush x:Key="Brush.ComboFocusMain" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.ComboDropdownBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.ComboItemHover" Color="#F1F1F4" />
