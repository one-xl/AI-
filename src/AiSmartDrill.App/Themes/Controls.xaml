<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         全局常量：圆角半径
         ═══════════════════════════════════════════════════════════ -->
    <CornerRadius x:Key="Radius.Sm">4</CornerRadius>
    <CornerRadius x:Key="Radius.Md">6</CornerRadius>
    <CornerRadius x:Key="Radius.Lg">10</CornerRadius>

    <!-- ═══════════════════════════════════════════════════════════
         基础元素
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource Brush.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <StackPanel>
                        <TextBlock Margin="2,0,0,8"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text}"
                                   Text="{TemplateBinding Header}" />
                        <Border Padding="16"
                                Background="{DynamicResource Brush.Surface}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Lg}">
                            <ContentPresenter />
                        </Border>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         TextBox：圆角输入框
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource Brush.InputBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.InputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Md}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         Button：按下 蓄力→弹出 动画 + 圆角
         RenderTransform 与 Storyboard 均在 ControlTemplate 内，
         避免主题切换时 Style 级 Storyboard 引用旧 Transform 崩溃。
         ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="ChromeButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Brush.ButtonBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Margin" Value="0,0,10,10" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ChromeBd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Md}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ChromeBd" Property="Background" Value="{DynamicResource Brush.ButtonHover}" />
                            <Setter TargetName="ChromeBd" Property="BorderBrush" Value="{DynamicResource Brush.ButtonHoverBorder}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                        <!-- 蓄力→弹出：全部在 ControlTemplate 内，安全于主题切换 -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="BtnPressDown">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.94" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.94" Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="BtnPressDown" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.0" Duration="0:0:0.22"
                                                         DecelerationRatio="0.6" />
                                        <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.0" Duration="0:0:0.22"
                                                         DecelerationRatio="0.6" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}" />

    <!-- 考试客观题选项按钮 -->
    <Style x:Key="ExamOptionButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.InputBackground}" />
        <Setter Property="BorderThickness" Value="1" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                <Setter Property="BorderThickness" Value="2" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         ComboBox：圆角 + 焦点高亮
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource Brush.InputBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.InputBorder}" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="MainBorder"
                                Background="{DynamicResource Brush.InputBackground}"
                                BorderBrush="{DynamicResource Brush.InputBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Md}"
                                Padding="10,8">
                            <Grid>
                                <!-- 整块区域可点：透明 Toggle 铺满，前景仅展示不参与命中 -->
                                <ToggleButton x:Name="ToggleButton"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              Focusable="False"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Grid IsHitTestVisible="False">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Stretch"
                                                      TextElement.Foreground="{DynamicResource Brush.Text}" />
                                    <Path Grid.Column="1"
                                          Margin="8,0,0,0"
                                          Fill="{DynamicResource Brush.TextMuted}"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 4 4 L 8 0 Z" />
                                </Grid>
                            </Grid>
                        </Border>
                        <Popup Placement="Bottom"
                               PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="{DynamicResource Brush.ComboDropdownBackground}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    Margin="0,2,0,0"
                                    Padding="0,4">
                                <ScrollViewer Margin="4,2" SnapsToDevicePixels="True">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="{DynamicResource Brush.ComboHoverMain}" />
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}"
                            Margin="2,1">
                        <ContentPresenter VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource Brush.Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.OnAccent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource Brush.ComboItemHover}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource Brush.Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.OnAccent}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         TabControl + TabItem：蓄力→弹出 切换动画 + 底部指示条
         动画在 ControlTemplate 内的具名 ScaleTransform 上运行，
         主题切换不会干扰。
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Padding" Value="18,11" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TabItemText}" />
        <Setter Property="Background" Value="{DynamicResource Brush.TabItemBackground}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid x:Name="Root"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="TabScale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Border x:Name="Border"
                                Background="{DynamicResource Brush.TabItemBackground}"
                                BorderThickness="0"
                                CornerRadius="6,6,0,0"
                                Padding="16,10">
                            <TextBlock x:Name="HeaderContent"
                                       Text="{TemplateBinding Header}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TabItemText}" />
                        </Border>
                        <Border x:Name="Indicator"
                                Height="3"
                                VerticalAlignment="Bottom"
                                CornerRadius="2,2,0,0"
                                Background="Transparent"
                                Margin="8,0" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource Brush.TabItemSelectedBackground}" />
                            <Setter TargetName="HeaderContent" Property="Foreground" Value="{DynamicResource Brush.Accent}" />
                            <Setter TargetName="HeaderContent" Property="FontWeight" Value="SemiBold" />
                            <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource Brush.Accent}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TabScale"
                                                                       Storyboard.TargetProperty="ScaleX">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.06" Value="0.92" />
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="1.0">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.35" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TabScale"
                                                                       Storyboard.TargetProperty="ScaleY">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.06" Value="0.92" />
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="1.0">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.35" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource Brush.TabItemHoverBackground}" />
                            <Setter TargetName="HeaderContent" Property="Foreground" Value="{DynamicResource Brush.Text}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         DataGrid 系列
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource Brush.DataGridBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="{DynamicResource Brush.DataGridBackground}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource Brush.DataGridRowAlt}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="RowHeight" Value="40" />
        <Setter Property="ColumnHeaderHeight" Value="42" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource Brush.DataGridHeaderBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.DataGridCellSelected}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         ListBox / ListBoxItem
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource Brush.ListBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="Padding" Value="8,5" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.ListItemSelected}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.ListItemHover}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         CheckBox
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         ProgressBar：仅用配色，保留系统模板以支持 IsIndeterminate 动画。
         ═══════════════════════════════════════════════════════════ -->
    <Style TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="Background" Value="{DynamicResource Brush.ProgressTrack}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="6" />
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceElevated}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceElevated}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
    </Style>

</ResourceDictionary>
